{
  "expo": {
    "name": "VoltFly EV",
    "slug": "voltfly-rider",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/one.png",
    "scheme": "voltflyrider",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/one.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.voltfly.rider",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Voltfly sends you alerts for payment reminders, KYC status updates, and important account notifications."
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "package": "com.voltflyrider",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/one.png",
        "backgroundColor": "#ffffff"
      },
      "runtimeVersion": "1.0.0"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/one.png"
    },
    "plugins": [
      [
        "expo-asset",
        {
          "assets": [
            "./assets/adi-registration.properties"
          ]
        }
      ],
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/one.png",
          "color": "#1D4ED8",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "VoltFly EV"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Voltfly needs camera access for KYC document photos"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Voltfly needs photo access for KYC documents"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "targetSdkVersion": 35,
            "compileSdkVersion": 35
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f9ef1d5e-f537-445a-b5ab-caed30d6d640"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/f9ef1d5e-f537-445a-b5ab-caed30d6d640"
    }
  }
}
